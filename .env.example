# FileApple 环境变量配置
# 复制此文件为 .env 并填写真实值

#========================================
# 服务配置
#========================================
API_PORT=8866
API_HOST=0.0.0.0

#========================================
# 目录配置
#========================================
BASE_DIR=/root/.openclaw/workspace/learning
UPLOADS_DIR=${BASE_DIR}/uploads
CHUNKS_DIR=${BASE_DIR}/chunks
TRANSCRIPTS_DIR=${BASE_DIR}/transcripts
DOWNLOADS_DIR=${BASE_DIR}/downloads
CHECKPOINTS_DIR=${BASE_DIR}/checkpoints
DATABASE_DIR=${BASE_DIR}

#========================================
# RAGFlow 配置
#========================================
# RAGFlow 服务地址
RAGFLOW_BASE_URL=http://localhost:9380

# RAGFlow API Token (在 RAGFlow 管理界面生成)
RAGFLOW_API_KEY=your-ragflow-api-key-here

# 知识库映射 (初始化后自动填充)
RAGFLOW_DATASET_TECHOPS=
RAGFLOW_DATASET_PSYCHOLOGY=
RAGFLOW_DATASET_RELATIONSHIP=
RAGFLOW_DATASET_DOCUMENTS=
RAGFLOW_DATASET_AUDIOBOOKS=
RAGFLOW_DATASET_GENERAL=

#========================================
# OpenViking 记忆系统
#========================================
OV_BASE_URL=http://localhost:1933
OV_API_KEY=openviking-root-key-2026

#========================================
# Hindsight 记忆系统
#========================================
HS_BASE_URL=http://localhost:8888
HS_BANK_ID=shared

#========================================
# LLM 配置 (用于知识导入)
#========================================
LLM_BASE_URL=http://192.168.0.167:11435/v1
LLM_API_KEY=EMPTY
LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

#========================================
# Embedding 配置
#========================================
EMBEDDING_BASE_URL=http://192.168.0.167:11436/v1
EMBEDDING_API_KEY=EMPTY
EMBEDDING_MODEL_NAME=BAAI/bge-m3

#========================================
# Whisper 转写配置
#========================================
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
